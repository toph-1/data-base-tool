#!/bin/bash

# Database directory
DB_DIR="$HOME/.payload_db"
USERS_FILE="$DB_DIR/users.txt"           # Main system users
PAYLOADS_FILE="$DB_DIR/payloads.txt"     # Payload information
PAYLOAD_CREDS_FILE="$DB_DIR/payload_creds.txt"  # Each payload's login/password

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Initialize database
init_db() {
    mkdir -p "$DB_DIR"
    
    # Create files with headers if they don't exist
    if [ ! -f "$USERS_FILE" ]; then
        echo "# username:hashed_password:created_at:last_login" > "$USERS_FILE"
    fi
    
    if [ ! -f "$PAYLOADS_FILE" ]; then
        echo "# payload_id|payload_name|type|port|status|owner|created_at|last_connected" > "$PAYLOADS_FILE"
    fi
    
    if [ ! -f "$PAYLOAD_CREDS_FILE" ]; then
        echo "# payload_id|service_username|service_password|notes" > "$PAYLOAD_CREDS_FILE"
    fi
    
    chmod 700 "$DB_DIR"
    chmod 600 "$USERS_FILE" "$PAYLOADS_FILE" "$PAYLOAD_CREDS_FILE"
    
    echo -e "${GREEN}✅ Database initialized at $DB_DIR${NC}"
}

# Hash password with salt
hash_password() {
    local password=$1
    local salt=$(openssl rand -base64 16)
    local hash=$(echo -n "$password$salt" | sha256sum | cut -d' ' -f1)
    echo "$salt:$hash"
}

# Verify password
verify_password() {
    local password=$1
    local stored=$2
    local salt=$(echo "$stored" | cut -d: -f1)
    local expected_hash=$(echo "$stored" | cut -d: -f2)
    local actual_hash=$(echo -n "$password$salt" | sha256sum | cut -d' ' -f1)
    [ "$actual_hash" = "$expected_hash" ]
}

# Add new system user
add_user() {
    echo -e "${BLUE}=== Add New System User ===${NC}"
    read -p "Username: " username
    
    # Check if user exists
    if grep -q "^$username:" "$USERS_FILE" 2>/dev/null; then
        echo -e "${RED}❌ User already exists!${NC}"
        return 1
    fi
    
    read -sp "Password: " password
    echo
    read -sp "Confirm password: " password2
    echo
    
    if [ "$password" != "$password2" ]; then
        echo -e "${RED}❌ Passwords don't match!${NC}"
        return 1
    fi
    
    if [ ${#password} -lt 4 ]; then
        echo -e "${RED}❌ Password must be at least 4 characters!${NC}"
        return 1
    fi
    
    local hashed=$(hash_password "$password")
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    echo "$username:$hashed:$timestamp:never" >> "$USERS_FILE"
    
    echo -e "${GREEN}✅ User $username added successfully!${NC}"
}

# Login system
login() {
    local attempts=0
    local max_attempts=3
    
    while [ $attempts -lt $max_attempts ]; do
        echo -e "${BLUE}=== Login ===${NC}"
        read -p "Username: " username
        read -sp "Password: " password
        echo
        
        local user_line=$(grep "^$username:" "$USERS_FILE" 2>/dev/null)
        
        if [ -n "$user_line" ]; then
            local stored_hash=$(echo "$user_line" | cut -d: -f2)
            if verify_password "$password" "$stored_hash"; then
                echo -e "${GREEN}✅ Login successful!${NC}"
                # Update last login
                local now=$(date '+%Y-%m-%d %H:%M:%S')
                sed -i "s/^$username:.*:.*:.*$/$username:$stored_hash:$(echo "$user_line" | cut -d: -f3):$now/" "$USERS_FILE"
                CURRENT_USER="$username"
                return 0
            fi
        fi
        
        attempts=$((attempts + 1))
        echo -e "${RED}❌ Login failed! ($attempts/$max_attempts attempts)${NC}"
        
        if [ $attempts -eq $max_attempts ]; then
            echo -e "${RED}🔒 Too many failed attempts. Exiting...${NC}"
            exit 1
        fi
    done
}

# Add new payload with its own credentials
add_payload() {
    echo -e "${BLUE}=== Add New Payload ===${NC}"
    
    read -p "Payload name: " payload_name
    read -p "Payload type (meterpreter/shell/ssh/web): " payload_type
    read -p "IP/Hostname: " payload_host
    read -p "Port: " payload_port
    
    # Validate port
    if [[ ! "$payload_port" =~ ^[0-9]+$ ]] || [ "$payload_port" -lt 1 ] || [ "$payload_port" -gt 65535 ]; then
        echo -e "${RED}❌ Invalid port number!${NC}"
        return 1
    fi
    
    echo -e "${YELLOW}--- Credentials for this payload ---${NC}"
    read -p "Service username (e.g., root, admin): " service_user
    read -sp "Service password: " service_pass
    echo
    read -p "Additional notes (optional): " notes
    
    # Generate unique payload ID
    payload_id=$(openssl rand -hex 8)
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    
    # Save payload info
    echo "$payload_id|$payload_name|$payload_type|$payload_port|disconnected|$CURRENT_USER|$timestamp|never" >> "$PAYLOADS_FILE"
    
    # Save payload credentials (encrypted with base64 for basic protection)
    local encoded_pass=$(echo -n "$service_pass" | base64)
    echo "$payload_id|$service_user|$encoded_pass|$notes" >> "$PAYLOAD_CREDS_FILE"
    
    echo -e "${GREEN}✅ Payload added successfully!${NC}"
    echo -e "${YELLOW}Payload ID: $payload_id${NC}"
}

# List all payloads with their credentials
list_payloads() {
    echo -e "${BLUE}=== All Payloads ===${NC}"
    
    if [ ! -s "$PAYLOADS_FILE" ] || [ $(cat "$PAYLOADS_FILE" | wc -l) -le 1 ]; then
        echo -e "${YELLOW}No payloads found${NC}"
        return
    fi
    
    echo -e "${GREEN}Payloads owned by you:${NC}"
    echo "--------------------------------------------------------------------------------------------------"
    printf "%-20s %-15s %-15s %-10s %-15s %-20s\n" "ID" "Name" "Type" "Port" "Status" "Created"
    echo "--------------------------------------------------------------------------------------------------"
    
    tail -n +2 "$PAYLOADS_FILE" | grep "|$CURRENT_USER|" | while IFS='|' read -r id name type port status owner created last_conn; do
        printf "%-20s %-15s %-15s %-10s %-15s %-20s\n" "$id" "$name" "$type" "$port" "$status" "$created"
    done
}

# Show credentials for a specific payload
show_payload_credentials() {
    echo -e "${BLUE}=== Show Payload Credentials ===${NC}"
    read -p "Enter Payload ID: " payload_id
    
    # Check if user owns this payload
    if ! grep -q "^$payload_id|.*|$CURRENT_USER|" "$PAYLOADS_FILE"; then
        echo -e "${RED}❌ Payload not found or you don't have permission!${NC}"
        return 1
    fi
    
    # Get payload info
    local payload_info=$(grep "^$payload_id|" "$PAYLOADS_FILE")
    local payload_name=$(echo "$payload_info" | cut -d'|' -f2)
    local payload_type=$(echo "$payload_info" | cut -d'|' -f3)
    local payload_port=$(echo "$payload_info" | cut -d'|' -f4)
    
    # Get credentials
    local creds=$(grep "^$payload_id|" "$PAYLOAD_CREDS_FILE")
    local service_user=$(echo "$creds" | cut -d'|' -f2)
    local encoded_pass=$(echo "$creds" | cut -d'|' -f3)
    local notes=$(echo "$creds" | cut -d'|' -f4)
    local service_pass=$(echo "$encoded_pass" | base64 -d 2>/dev/null)
    
    echo -e "${GREEN}========================================${NC}"
    echo -e "${YELLOW}Payload: $payload_name${NC}"
    echo -e "${YELLOW}Type: $payload_type${NC}"
    echo -e "${YELLOW}Port: $payload_port${NC}"
    echo -e "${GREEN}----------------------------------------${NC}"
    echo -e "${GREEN}Login Credentials:${NC}"
    echo -e "  Username: ${BLUE}$service_user${NC}"
    echo -e "  Password: ${BLUE}$service_pass${NC}"
    echo -e "  Notes: ${BLUE}$notes${NC}"
    echo -e "${GREEN}========================================${NC}"
}

# Connect to a payload (mark as connected and show creds)
connect_payload() {
    echo -e "${BLUE}=== Connect to Payload ===${NC}"
    list_payloads
    
    read -p "Enter Payload ID to connect: " payload_id
    
    # Check if user owns this payload
    if ! grep -q "^$payload_id|.*|$CURRENT_USER|" "$PAYLOADS_FILE"; then
        echo -e "${RED}❌ Payload not found or you don't have permission!${NC}"
        return 1
    fi
    
    # Show credentials first
    echo -e "${YELLOW}Retrieving credentials...${NC}"
    show_payload_credentials
    
    # Update status to connected
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    sed -i "s/^$payload_id|\([^|]*\)|\([^|]*\)|\([^|]*\)|disconnected|\([^|]*\)|\([^|]*\)|.*$/$payload_id|\1|\2|\3|connected|\4|\5|$timestamp/" "$PAYLOADS_FILE"
    
    echo -e "${GREEN}✅ Payload marked as connected!${NC}"
    echo -e "${YELLOW}Use the credentials above to connect to your payload.${NC}"
}

# Disconnect payload
disconnect_payload() {
    echo -e "${BLUE}=== Disconnect Payload ===${NC}"
    read -p "Enter Payload ID: " payload_id
    
    if ! grep -q "^$payload_id|.*|$CURRENT_USER|" "$PAYLOADS_FILE"; then
        echo -e "${RED}❌ Payload not found or you don't have permission!${NC}"
        return 1
    fi
    
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    sed -i "s/^$payload_id|\([^|]*\)|\([^|]*\)|\([^|]*\)|connected|\([^|]*\)|\([^|]*\)|.*$/$payload_id|\1|\2|\3|disconnected|\4|\5|$timestamp/" "$PAYLOADS_FILE"
    
    echo -e "${GREEN}✅ Payload disconnected${NC}"
}

# Show connected payloads
show_connected() {
    echo -e "${BLUE}=== Connected Payloads ===${NC}"
    echo "--------------------------------------------------------------------------------------------------"
    printf "%-20s %-15s %-15s %-10s %-20s\n" "ID" "Name" "Type" "Port" "Last Connected"
    echo "--------------------------------------------------------------------------------------------------"
    
    tail -n +2 "$PAYLOADS_FILE" | grep "|connected|$CURRENT_USER|" | while IFS='|' read -r id name type port status owner created last_conn; do
        printf "%-20s %-15s %-15s %-10s %-20s\n" "$id" "$name" "$type" "$port" "$last_conn"
    done
}

# Export all my payloads with credentials
export_my_payloads() {
    echo -e "${BLUE}=== Export My Payloads ===${NC}"
    local export_file="$DB_DIR/${CURRENT_USER}_payloads_export_$(date '+%Y%m%d_%H%M%S').txt"
    
    echo "=== Payload Export for $CURRENT_USER ===" > "$export_file"
    echo "Generated: $(date)" >> "$export_file"
    echo "" >> "$export_file"
    
    tail -n +2 "$PAYLOADS_FILE" | grep "|$CURRENT_USER|" | while IFS='|' read -r id name type port status owner created last_conn; do
        local creds=$(grep "^$id|" "$PAYLOAD_CREDS_FILE")
        local service_user=$(echo "$creds" | cut -d'|' -f2)
        local encoded_pass=$(echo "$creds" | cut -d'|' -f3)
        local notes=$(echo "$creds" | cut -d'|' -f4)
        local service_pass=$(echo "$encoded_pass" | base64 -d 2>/dev/null)
        
        echo "----------------------------------------" >> "$export_file"
        echo "Payload: $name (ID: $id)" >> "$export_file"
        echo "Type: $type | Port: $port | Status: $status" >> "$export_file"
        echo "Created: $created | Last Connected: $last_conn" >> "$export_file"
        echo "Credentials:" >> "$export_file"
        echo "  Username: $service_user" >> "$export_file"
        echo "  Password: $service_pass" >> "$export_file"
        echo "  Notes: $notes" >> "$export_file"
        echo "" >> "$export_file"
    done
    
    chmod 600 "$export_file"
    echo -e "${GREEN}✅ Exported to: $export_file${NC}"
}

# Search payloads
search_payloads() {
    echo -e "${BLUE}=== Search Payloads ===${NC}"
    read -p "Search term: " search_term
    
    echo "--------------------------------------------------------------------------------------------------"
    printf "%-20s %-15s %-15s %-10s %-15s\n" "ID" "Name" "Type" "Port" "Status"
    echo "--------------------------------------------------------------------------------------------------"
    
    tail -n +2 "$PAYLOADS_FILE" | grep "|$CURRENT_USER|" | grep -i "$search_term" | while IFS='|' read -r id name type port status owner created last_conn; do
        printf "%-20s %-15s %-15s %-10s %-15s\n" "$id" "$name" "$type" "$port" "$status"
    done
}

# Main menu
main_menu() {
    while true; do
        echo
        echo -e "${BLUE}╔══════════════════════════════════════════════════╗${NC}"
        echo -e "${BLUE}║     Payload Database Manager - Main Menu        ║${NC}"
        echo -e "${BLUE}╚══════════════════════════════════════════════════╝${NC}"
        echo "1) Login"
        echo "2) Add New System User"
        echo "3) Exit"
        read -p "Choice: " choice
        
        case $choice in
            1) if login; then payload_menu; fi ;;
            2) add_user ;;
            3) exit 0 ;;
            *) echo -e "${RED}❌ Invalid choice${NC}" ;;
        esac
    done
}

# Payload management menu (after login)
payload_menu() {
    while true; do
        echo
        echo -e "${GREEN}╔══════════════════════════════════════════════════╗${NC}"
        echo -e "${GREEN}║     Payload Management - Logged in as: $CURRENT_USER     ║${NC}"
        echo -e "${GREEN}╚══════════════════════════════════════════════════╝${NC}"
        echo "1) Add New Payload (with credentials)"
        echo "2) List My Payloads"
        echo "3) Show Payload Credentials"
        echo "4) Connect to Payload (show creds & mark connected)"
        echo "5) Show Connected Payloads"
        echo "6) Disconnect Payload"
        echo "7) Search Payloads"
        echo "8) Export All My Payloads"
        echo "9) Logout"
        read -p "Choice: " choice
        
        case $choice in
            1) add_payload ;;
            2) list_payloads ;;
            3) show_payload_credentials ;;
            4) connect_payload ;;
            5) show_connected ;;
            6) disconnect_payload ;;
            7) search_payloads ;;
            8) export_my_payloads ;;
            9) break ;;
            *) echo -e "${RED}❌ Invalid choice${NC}" ;;
        esac
    done
}

# Run the application
clear
echo -e "${GREEN}🔒 Payload Database Manager v3.0${NC}"
echo "========================================"
init_db
main_menu
