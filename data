#!/usr/bin/env python3
"""
PAYLOAD DATABASE CLIENT - Integrated version for your script
"""

import socket
import json
import getpass
import os

class PayloadDB:
    def __init__(self, server_ip='10.2.0.2', server_port=5555):
        self.server_ip = server_ip
        self.server_port = server_port
        self.api_key = None
        self.username = None
    
    def send_request(self, request):
        """Send request to database server"""
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.connect((self.server_ip, self.server_port))
            sock.send(json.dumps(request).encode())
            response = json.loads(sock.recv(65536).decode())
            sock.close()
            return response
        except Exception as e:
            print(f"[-] Connection error: {e}")
            return None
    
    def register(self, username, password):
        """Register new user"""
        response = self.send_request({
            'action': 'register',
            'username': username,
            'password': password
        })
        
        if response and response.get('status') == 'success':
            self.api_key = response.get('api_key')
            self.username = username
            # Save API key for later use
            with open(os.path.expanduser('~/.payload_api.key'), 'w') as f:
                f.write(self.api_key)
            return True, response.get('api_key')
        return False, response.get('message', 'Registration failed')
    
    def login(self, api_key=None):
        """Login with API key"""
        if not api_key:
            # Try to load saved API key
            try:
                with open(os.path.expanduser('~/.payload_api.key'), 'r') as f:
                    api_key = f.read().strip()
            except:
                pass
        
        if not api_key:
            return False, "No API key provided"
        
        # Verify by trying to get payloads
        response = self.send_request({
            'action': 'get_payloads',
            'api_key': api_key
        })
        
        if response and response.get('status') == 'success':
            self.api_key = api_key
            self.username = "user"
            return True, "Login successful"
        return False, "Invalid API key"
    
    def save_payload(self, name, ptype, lhost, lport, payload_code):
        """Save a payload to database"""
        if not self.api_key:
            return False, "Not logged in"
        
        response = self.send_request({
            'action': 'save_payload',
            'api_key': self.api_key,
            'name': name,
            'type': ptype,
            'lhost': lhost,
            'lport': lport,
            'payload': payload_code
        })
        
        if response and response.get('status') == 'success':
            return True, response.get('id')
        return False, response.get('message', 'Failed to save')
    
    def get_payloads(self):
        """Get all payloads"""
        if not self.api_key:
            return False, []
        
        response = self.send_request({
            'action': 'get_payloads',
            'api_key': self.api_key
        })
        
        if response and response.get('status') == 'success':
            return True, response.get('payloads', [])
        return False, []
    
    def delete_payload(self, payload_id):
        """Delete a payload"""
        if not self.api_key:
            return False, "Not logged in"
        
        response = self.send_request({
            'action': 'delete_payload',
            'api_key': self.api_key,
            'payload_id': payload_id
        })
        
        if response and response.get('status') == 'success':
            return True, response.get('message')
        return False, response.get('message', 'Failed to delete')
    
    def save_password(self, target_ip, target_hostname, username, password, source):
        """Save captured password"""
        if not self.api_key:
            return False, "Not logged in"
        
        response = self.send_request({
            'action': 'save_password',
            'api_key': self.api_key,
            'target_ip': target_ip,
            'target_hostname': target_hostname,
            'username': username,
            'password': password,
            'source': source
        })
        
        if response and response.get('status') == 'success':
            return True, "Password saved"
        return False, response.get('message', 'Failed to save')
    
    def get_passwords(self):
        """Get all captured passwords"""
        if not self.api_key:
            return False, []
        
        response = self.send_request({
            'action': 'get_passwords',
            'api_key': self.api_key
        })
        
        if response and response.get('status') == 'success':
            return True, response.get('passwords', [])
        return False, []

