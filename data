#!/usr/bin/env python3
"""
PAYLOAD DATABASE CLIENT - Number Menu
"""

import os
import sys
import socket
import json
import getpass
import time

class Colors:
    GREEN = '\033[92m'
    YELLOW = '\033[93m'
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    RED = '\033[91m'
    WHITE = '\033[97m'
    BOLD = '\033[1m'
    RESET = '\033[0m'

class PayloadClient:
    def __init__(self, server_host, server_port):
        self.server_host = server_host
        self.server_port = server_port
        self.api_key = None
        self.username = None
        
    def send_request(self, request):
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.connect((self.server_host, self.server_port))
            sock.send(json.dumps(request).encode())
            response = sock.recv(65536).decode()
            sock.close()
            return json.loads(response)
        except Exception as e:
            print(f"{Colors.RED}[-] Connection error: {e}{Colors.RESET}")
            return None
            
    def register(self):
        print(f"\n{Colors.CYAN}[*] Register New Account{Colors.RESET}\n")
        
        username = input(f"{Colors.WHITE}Username: {Colors.RESET}")
        password = getpass.getpass(f"{Colors.WHITE}Password: {Colors.RESET}")
        confirm = getpass.getpass(f"{Colors.WHITE}Confirm: {Colors.RESET}")
        
        if password != confirm:
            print(f"{Colors.RED}[-] Passwords don't match{Colors.RESET}")
            return False
            
        response = self.send_request({
            "action": "register",
            "username": username,
            "password": password
        })
        
        if response and response.get('status') == 'success':
            self.api_key = response.get('api_key')
            self.username = username
            print(f"{Colors.GREEN}[+] Registered! Save this API key:{Colors.RESET}")
            print(f"{Colors.YELLOW}{self.api_key}{Colors.RESET}")
            input(f"{Colors.DIM}Press Enter...{Colors.RESET}")
            return True
        else:
            print(f"{Colors.RED}[-] {response.get('message', 'Registration failed')}{Colors.RESET}")
            return False
            
    def login(self):
        print(f"\n{Colors.CYAN}[*] Login{Colors.RESET}\n")
        
        self.api_key = input(f"{Colors.WHITE}API Key: {Colors.RESET}")
        self.username = "user"
        
        response = self.send_request({
            "action": "get_payloads",
            "api_key": self.api_key
        })
        
        if response and response.get('status') == 'success':
            print(f"{Colors.GREEN}[+] Login successful!{Colors.RESET}")
            time.sleep(1)
            return True
        else:
            print(f"{Colors.RED}[-] Invalid API key{Colors.RESET}")
            return False
            
    def save_payload(self):
        print(f"\n{Colors.CYAN}[*] Save Payload{Colors.RESET}\n")
        
        name = input(f"{Colors.WHITE}Name: {Colors.RESET}")
        ptype = input(f"{Colors.WHITE}Type: {Colors.RESET}")
        lhost = input(f"{Colors.WHITE}LHOST: {Colors.RESET}")
        lport = input(f"{Colors.WHITE}LPORT: {Colors.RESET}")
        
        print(f"{Colors.YELLOW}[!] Paste payload (end with 'END'):{Colors.RESET}")
        lines = []
        while True:
            line = input()
            if line == "END":
                break
            lines.append(line)
        payload = "\n".join(lines)
        
        response = self.send_request({
            "action": "save_payload",
            "api_key": self.api_key,
            "name": name,
            "type": ptype,
            "lhost": lhost,
            "lport": lport,
            "payload": payload
        })
        
        if response and response.get('status') == 'success':
            print(f"{Colors.GREEN}[+] Payload saved! ID: {response.get('id')}{Colors.RESET}")
        else:
            print(f"{Colors.RED}[-] Failed to save{Colors.RESET}")
        input(f"{Colors.DIM}Press Enter...{Colors.RESET}")
        
    def view_payloads(self):
        response = self.send_request({
            "action": "get_payloads",
            "api_key": self.api_key
        })
        
        if not response or response.get('status') != 'success':
            print(f"{Colors.RED}[-] Failed to get payloads{Colors.RESET}")
            input(f"{Colors.DIM}Press Enter...{Colors.RESET}")
            return
            
        payloads = response.get('payloads', [])
        
        os.system('clear')
        print(f"\n{Colors.CYAN}{'='*80}{Colors.RESET}")
        print(f"{Colors.BOLD}     YOUR PAYLOADS{Colors.RESET}")
        print(f"{Colors.CYAN}{'='*80}{Colors.RESET}\n")
        
        if not payloads:
            print(f"{Colors.YELLOW}[!] No payloads{Colors.RESET}")
        else:
            print(f"{Colors.GREEN}{'ID':<4} {'Name':<20} {'Type':<10} {'LHOST':<16} {'LPORT':<8} {'Created':<20}{Colors.RESET}")
            print(f"{Colors.DIM}{'-'*80}{Colors.RESET}")
            for p in payloads:
                print(f"{p[0]:<4} {p[1]:<20} {p[2]:<10} {p[3] or '-':<16} {p[4] or '-':<8} {p[5][:19]:<20}")
                
        input(f"\n{Colors.DIM}Press Enter...{Colors.RESET}")
        
    def save_password(self):
        print(f"\n{Colors.CYAN}[*] Save Captured Password{Colors.RESET}\n")
        
        target_ip = input(f"{Colors.WHITE}Target IP: {Colors.RESET}")
        target_hostname = input(f"{Colors.WHITE}Hostname: {Colors.RESET}")
        username = input(f"{Colors.WHITE}Username: {Colors.RESET}")
        password = input(f"{Colors.WHITE}Password: {Colors.RESET}")
        source = input(f"{Colors.WHITE}Source: {Colors.RESET}")
        
        response = self.send_request({
            "action": "save_password",
            "api_key": self.api_key,
            "target_ip": target_ip,
            "target_hostname": target_hostname,
            "username": username,
            "password": password,
            "source": source
        })
        
        if response and response.get('status') == 'success':
            print(f"{Colors.GREEN}[+] Password saved!{Colors.RESET}")
        else:
            print(f"{Colors.RED}[-] Failed to save{Colors.RESET}")
        input(f"{Colors.DIM}Press Enter...{Colors.RESET}")
        
    def view_passwords(self):
        response = self.send_request({
            "action": "get_passwords",
            "api_key": self.api_key
        })
        
        if not response or response.get('status') != 'success':
            print(f"{Colors.RED}[-] Failed to get passwords{Colors.RESET}")
            input(f"{Colors.DIM}Press Enter...{Colors.RESET}")
            return
            
        passwords = response.get('passwords', [])
        
        os.system('clear')
        print(f"\n{Colors.CYAN}{'='*100}{Colors.RESET}")
        print(f"{Colors.BOLD}     CAPTURED PASSWORDS{Colors.RESET}")
        print(f"{Colors.CYAN}{'='*100}{Colors.RESET}\n")
        
        if not passwords:
            print(f"{Colors.YELLOW}[!] No passwords{Colors.RESET}")
        else:
            print(f"{Colors.GREEN}{'ID':<4} {'IP':<16} {'Hostname':<20} {'Username':<20} {'Password':<20} {'Source':<12} {'Date':<20}{Colors.RESET}")
            print(f"{Colors.DIM}{'-'*100}{Colors.RESET}")
            for p in passwords:
                print(f"{p[0]:<4} {p[1]:<16} {p[2]:<20} {p[3]:<20} {p[4]:<20} {p[5]:<12} {p[6][:19]:<20}")
                
        input(f"\n{Colors.DIM}Press Enter...{Colors.RESET}")
        
    def delete_payload(self):
        pid = input(f"\n{Colors.WHITE}Payload ID to delete: {Colors.RESET}")
        
        response = self.send_request({
            "action": "delete_payload",
            "api_key": self.api_key,
            "payload_id": int(pid)
        })
        
        if response and response.get('status') == 'success':
            print(f"{Colors.GREEN}[+] Payload deleted{Colors.RESET}")
        else:
            print(f"{Colors.RED}[-] Failed to delete{Colors.RESET}")
        input(f"{Colors.DIM}Press Enter...{Colors.RESET}")
        
    def show_api_key(self):
        print(f"\n{Colors.CYAN}[*] Your API Key:{Colors.RESET}")
        print(f"{Colors.YELLOW}{self.api_key}{Colors.RESET}")
        print(f"{Colors.DIM}Save this key to login from anywhere!{Colors.RESET}")
        input(f"\n{Colors.DIM}Press Enter...{Colors.RESET}")
        
    def run(self):
        print(f"\n{Colors.CYAN}{'='*50}{Colors.RESET}")
        print(f"{Colors.BOLD}     PAYLOAD DATABASE CLIENT{Colors.RESET}")
        print(f"{Colors.CYAN}{'='*50}{Colors.RESET}")
        print(f"{Colors.WHITE}1.{Colors.RESET} Login (existing user)")
        print(f"{Colors.WHITE}2.{Colors.RESET} Register (new user)")
        
        choice = input(f"\n{Colors.GREEN}choice>{Colors.RESET} ")
        
        if choice == "1":
            if not self.login():
                return
        elif choice == "2":
            if not self.register():
                return
        else:
            return
            
        while True:
            os.system('clear')
            print(f"\n{Colors.CYAN}{'='*50}{Colors.RESET}")
            print(f"{Colors.BOLD}     PAYLOAD DATABASE{Colors.RESET}")
            print(f"{Colors.CYAN}{'='*50}{Colors.RESET}")
            print(f"{Colors.GREEN}[+] User: {self.username}{Colors.RESET}")
            print(f"{Colors.CYAN}{'='*50}{Colors.RESET}")
            print(f"{Colors.GREEN}1.{Colors.RESET} Save Payload")
            print(f"{Colors.GREEN}2.{Colors.RESET} View Payloads")
            print(f"{Colors.GREEN}3.{Colors.RESET} Delete Payload")
            print(f"{Colors.GREEN}4.{Colors.RESET} Save Captured Password")
            print(f"{Colors.GREEN}5.{Colors.RESET} View Captured Passwords")
            print(f"{Colors.GREEN}6.{Colors.RESET} Show API Key")
            print(f"{Colors.GREEN}0.{Colors.RESET} Exit")
            print(f"{Colors.CYAN}{'='*50}{Colors.RESET}")
            
            choice = input(f"{Colors.GREEN}choice>{Colors.RESET} ")
            
            if choice == "0":
                break
            elif choice == "1":
                self.save_payload()
            elif choice == "2":
                self.view_payloads()
            elif choice == "3":
                self.delete_payload()
            elif choice == "4":
                self.save_password()
            elif choice == "5":
                self.view_passwords()
            elif choice == "6":
                self.show_api_key()

def main():
    print(f"\n{Colors.CYAN}{'='*50}{Colors.RESET}")
    print(f"{Colors.BOLD}     PAYLOAD DATABASE CLIENT{Colors.RESET}")
    print(f"{Colors.CYAN}{'='*50}{Colors.RESET}")
    
    server_host = input(f"{Colors.WHITE}Server IP: {Colors.RESET}")
    server_port = input(f"{Colors.WHITE}Server Port: {Colors.RESET}")
    
    try:
        server_port = int(server_port)
    except:
        server_port = 5555
        
    client = PayloadClient(server_host, server_port)
    client.run()

if __name__ == "__main__":
    main()
