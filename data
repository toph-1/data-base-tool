#!/usr/bin/env python3
"""
PAYLOAD SHELL DATABASE - Stores Passwords & Payloads
Login protected | Save everything | No errors
"""

import os
import sys
import sqlite3
import hashlib
import getpass
import json
import time
from datetime import datetime

# Colors - Fixed all attributes
class Colors:
    RED = '\033[91m'
    GREEN = '\033[92m'
    YELLOW = '\033[93m'
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    WHITE = '\033[97m'
    PURPLE = '\033[95m'
    BOLD = '\033[1m'
    DIM = '\033[2m'
    RESET = '\033[0m'

class PayloadDatabase:
    def __init__(self):
        self.db_path = os.path.join(os.getcwd(), "payload_data.db")
        self.current_user = None
        self.init_db()
        
    def init_db(self):
        """Initialize all tables"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        # Users table (for login)
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS users (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                username TEXT UNIQUE NOT NULL,
                password_hash TEXT NOT NULL,
                salt TEXT NOT NULL,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        ''')
        
        # Payloads table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS payloads (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                name TEXT NOT NULL,
                type TEXT,
                lhost TEXT,
                lport INTEGER,
                payload TEXT,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                created_by TEXT
            )
        ''')
        
        # Captured passwords from targets
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS captured_passwords (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                target_ip TEXT,
                target_hostname TEXT,
                username TEXT,
                password TEXT,
                source TEXT,
                captured_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        ''')
        
        conn.commit()
        conn.close()
        
        # Create default admin if no users
        self.create_admin()
        
    def create_admin(self):
        """Create default admin account"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute("SELECT COUNT(*) FROM users")
        if cursor.fetchone()[0] == 0:
            salt = os.urandom(32).hex()
            password = "admin123"
            password_hash = hashlib.pbkdf2_hmac('sha256', password.encode(), salt.encode(), 100000).hex()
            cursor.execute("INSERT INTO users (username, password_hash, salt) VALUES (?, ?, ?)",
                          ("admin", password_hash, salt))
            conn.commit()
            print(f"{Colors.GREEN}[+] Created admin: admin / admin123{Colors.RESET}")
        conn.close()
        
    def login(self):
        """Login system"""
        attempts = 0
        while attempts < 3:
            os.system('clear')
            print(f"\n{Colors.CYAN}{'='*50}{Colors.RESET}")
            print(f"{Colors.BOLD}         PAYLOAD DATABASE LOGIN{Colors.RESET}")
            print(f"{Colors.CYAN}{'='*50}{Colors.RESET}\n")
            
            username = input(f"{Colors.WHITE}Username: {Colors.RESET}")
            password = getpass.getpass(f"{Colors.WHITE}Password: {Colors.RESET}")
            
            conn = sqlite3.connect(self.db_path)
            cursor = conn.cursor()
            cursor.execute("SELECT id, password_hash, salt FROM users WHERE username = ?", (username,))
            result = cursor.fetchone()
            conn.close()
            
            if result:
                user_id, stored_hash, salt = result
                password_hash = hashlib.pbkdf2_hmac('sha256', password.encode(), salt.encode(), 100000).hex()
                if password_hash == stored_hash:
                    self.current_user = {"id": user_id, "username": username}
                    print(f"\n{Colors.GREEN}[+] Welcome back, {username}!{Colors.RESET}")
                    time.sleep(1)
                    return True
                    
            attempts += 1
            print(f"\n{Colors.RED}[-] Invalid login. {3 - attempts} attempts left.{Colors.RESET}")
            time.sleep(1.5)
            
        return False
        
    def clear_screen(self):
        os.system('clear' if os.name == 'posix' else 'cls')
        
    def print_menu(self):
        """Print main menu with database location at top"""
        # Get counts
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute("SELECT COUNT(*) FROM payloads")
        payload_count = cursor.fetchone()[0]
        cursor.execute("SELECT COUNT(*) FROM captured_passwords")
        password_count = cursor.fetchone()[0]
        conn.close()
        
        menu = f"""
{Colors.CYAN}{'='*60}{Colors.RESET}
{Colors.BOLD}         PAYLOAD DATABASE{Colors.RESET}
{Colors.CYAN}{'='*60}{Colors.RESET}
{Colors.DIM}[ Database: {self.db_path} ]{Colors.RESET}
{Colors.CYAN}{'='*60}{Colors.RESET}
{Colors.GREEN}[+] User: {self.current_user['username']}{Colors.RESET}
{Colors.YELLOW}[+] Payloads: {payload_count}{Colors.RESET}
{Colors.BLUE}[+] Captured Passwords: {password_count}{Colors.RESET}
{Colors.CYAN}{'='*60}{Colors.RESET}

{Colors.GREEN}1.{Colors.RESET} Save Payload
{Colors.GREEN}2.{Colors.RESET} View Payloads
{Colors.GREEN}3.{Colors.RESET} View Payload
{Colors.GREEN}4.{Colors.RESET} Delete Payload
{Colors.GREEN}5.{Colors.RESET} Save Captured Password
{Colors.GREEN}6.{Colors.RESET} View Captured Passwords
{Colors.GREEN}7.{Colors.RESET} Search
{Colors.GREEN}8.{Colors.RESET} Export All Data
{Colors.GREEN}9.{Colors.RESET} Change Password
{Colors.GREEN}0.{Colors.RESET} Logout

{Colors.CYAN}{'='*60}{Colors.RESET}
"""
        print(menu)
        
    def save_payload(self):
        """Save a payload"""
        print(f"\n{Colors.CYAN}[*] Save Payload{Colors.RESET}\n")
        
        name = input(f"{Colors.WHITE}Payload Name: {Colors.RESET}")
        ptype = input(f"{Colors.WHITE}Type (ps1/exe/py/bash): {Colors.RESET}")
        lhost = input(f"{Colors.WHITE}LHOST: {Colors.RESET}")
        lport = input(f"{Colors.WHITE}LPORT: {Colors.RESET}")
        
        print(f"{Colors.YELLOW}[!] Paste your payload (end with 'END' on new line):{Colors.RESET}")
        lines = []
        while True:
            line = input()
            if line == "END":
                break
            lines.append(line)
        payload = "\n".join(lines)
        
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute('''
            INSERT INTO payloads (name, type, lhost, lport, payload, created_by)
            VALUES (?, ?, ?, ?, ?, ?)
        ''', (name, ptype, lhost, lport, payload, self.current_user['username']))
        conn.commit()
        conn.close()
        
        print(f"{Colors.GREEN}[+] Payload saved!{Colors.RESET}")
        input(f"\n{Colors.DIM}Press Enter...{Colors.RESET}")
        
    def view_payloads(self):
        """View all payloads"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute("SELECT id, name, type, lhost, lport, created_at FROM payloads ORDER BY id DESC")
        payloads = cursor.fetchall()
        conn.close()
        
        self.clear_screen()
        print(f"\n{Colors.CYAN}{'='*80}{Colors.RESET}")
        print(f"{Colors.BOLD}              PAYLOADS{Colors.RESET}")
        print(f"{Colors.CYAN}{'='*80}{Colors.RESET}\n")
        
        if not payloads:
            print(f"{Colors.YELLOW}[!] No payloads{Colors.RESET}")
        else:
            print(f"{Colors.GREEN}{'ID':<4} {'Name':<20} {'Type':<10} {'LHOST':<16} {'LPORT':<8} {'Created':<20}{Colors.RESET}")
            print(f"{Colors.DIM}{'-'*80}{Colors.RESET}")
            for p in payloads:
                print(f"{p[0]:<4} {p[1]:<20} {p[2]:<10} {p[3] or '-':<16} {p[4] or '-':<8} {str(p[5])[:19]:<20}")
                
        input(f"\n{Colors.DIM}Press Enter...{Colors.RESET}")
        
    def view_payload(self):
        """View a single payload"""
        pid = input(f"\n{Colors.WHITE}Payload ID: {Colors.RESET}")
        
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute("SELECT id, name, type, lhost, lport, payload, created_at FROM payloads WHERE id = ?", (pid,))
        p = cursor.fetchone()
        conn.close()
        
        if not p:
            print(f"{Colors.RED}[-] Payload not found{Colors.RESET}")
            input(f"{Colors.DIM}Press Enter...{Colors.RESET}")
            return
            
        self.clear_screen()
        print(f"\n{Colors.CYAN}{'='*60}{Colors.RESET}")
        print(f"{Colors.BOLD}  {p[1]}{Colors.RESET}")
        print(f"{Colors.CYAN}{'='*60}{Colors.RESET}")
        print(f"{Colors.YELLOW}ID:{Colors.RESET} {p[0]}")
        print(f"{Colors.YELLOW}Type:{Colors.RESET} {p[2]}")
        print(f"{Colors.YELLOW}LHOST:{Colors.RESET} {p[3]}")
        print(f"{Colors.YELLOW}LPORT:{Colors.RESET} {p[4]}")
        print(f"{Colors.YELLOW}Created:{Colors.RESET} {p[6]}")
        print(f"{Colors.CYAN}{'-'*60}{Colors.RESET}")
        print(f"{Colors.GREEN}Payload:{Colors.RESET}\n{p[5]}")
        print(f"{Colors.CYAN}{'='*60}{Colors.RESET}\n")
        
        input(f"{Colors.DIM}Press Enter...{Colors.RESET}")
        
    def delete_payload(self):
        """Delete a payload"""
        pid = input(f"\n{Colors.WHITE}Payload ID to delete: {Colors.RESET}")
        
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute("DELETE FROM payloads WHERE id = ?", (pid,))
        conn.commit()
        conn.close()
        
        print(f"{Colors.GREEN}[+] Payload deleted{Colors.RESET}")
        input(f"{Colors.DIM}Press Enter...{Colors.RESET}")
        
    def save_password(self):
        """Save a captured password from target"""
        print(f"\n{Colors.CYAN}[*] Save Captured Password{Colors.RESET}\n")
        
        target_ip = input(f"{Colors.WHITE}Target IP: {Colors.RESET}")
        target_hostname = input(f"{Colors.WHITE}Hostname: {Colors.RESET}")
        username = input(f"{Colors.WHITE}Username: {Colors.RESET}")
        password = input(f"{Colors.WHITE}Password: {Colors.RESET}")
        source = input(f"{Colors.WHITE}Source (browser/wifi/keylogger/etc): {Colors.RESET}")
        
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute('''
            INSERT INTO captured_passwords (target_ip, target_hostname, username, password, source)
            VALUES (?, ?, ?, ?, ?)
        ''', (target_ip, target_hostname, username, password, source))
        conn.commit()
        conn.close()
        
        print(f"{Colors.GREEN}[+] Password saved!{Colors.RESET}")
        input(f"\n{Colors.DIM}Press Enter...{Colors.RESET}")
        
    def view_passwords(self):
        """View all captured passwords"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute("SELECT id, target_ip, target_hostname, username, password, source, captured_at FROM captured_passwords ORDER BY id DESC")
        passwords = cursor.fetchall()
        conn.close()
        
        self.clear_screen()
        print(f"\n{Colors.CYAN}{'='*100}{Colors.RESET}")
        print(f"{Colors.BOLD}              CAPTURED PASSWORDS{Colors.RESET}")
        print(f"{Colors.CYAN}{'='*100}{Colors.RESET}\n")
        
        if not passwords:
            print(f"{Colors.YELLOW}[!] No passwords captured yet{Colors.RESET}")
        else:
            print(f"{Colors.GREEN}{'ID':<4} {'IP':<16} {'Hostname':<20} {'Username':<20} {'Password':<20} {'Source':<12} {'Date':<20}{Colors.RESET}")
            print(f"{Colors.DIM}{'-'*100}{Colors.RESET}")
            for p in passwords:
                print(f"{p[0]:<4} {p[1]:<16} {p[2]:<20} {p[3]:<20} {p[4]:<20} {p[5]:<12} {str(p[6])[:19]:<20}")
                
        input(f"\n{Colors.DIM}Press Enter...{Colors.RESET}")
        
    def search(self):
        """Search payloads and passwords"""
        keyword = input(f"\n{Colors.WHITE}Search keyword: {Colors.RESET}")
        
        self.clear_screen()
        print(f"\n{Colors.CYAN}{'='*80}{Colors.RESET}")
        print(f"{Colors.BOLD}     SEARCH RESULTS FOR '{keyword}'{Colors.RESET}")
        print(f"{Colors.CYAN}{'='*80}{Colors.RESET}\n")
        
        # Search payloads
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute("SELECT id, name, type, lhost, lport FROM payloads WHERE name LIKE ? OR payload LIKE ?", 
                      (f'%{keyword}%', f'%{keyword}%'))
        payloads = cursor.fetchall()
        
        if payloads:
            print(f"{Colors.GREEN}[PAYLOADS]{Colors.RESET}")
            for p in payloads:
                print(f"  [{p[0]}] {p[1]} ({p[2]}) - {p[3]}:{p[4]}")
                
        # Search passwords
        cursor.execute("SELECT id, target_ip, target_hostname, username, password FROM captured_passwords WHERE username LIKE ? OR password LIKE ? OR source LIKE ?",
                      (f'%{keyword}%', f'%{keyword}%', f'%{keyword}%'))
        passwords = cursor.fetchall()
        
        if passwords:
            print(f"\n{Colors.YELLOW}[PASSWORDS]{Colors.RESET}")
            for p in passwords:
                print(f"  [{p[0]}] {p[1]} - {p[2]} - {p[3]}:{p[4]}")
                
        if not payloads and not passwords:
            print(f"{Colors.RED}[!] No results{Colors.RESET}")
            
        conn.close()
        input(f"\n{Colors.DIM}Press Enter...{Colors.RESET}")
        
    def export(self):
        """Export all data to JSON"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        cursor.execute("SELECT * FROM payloads")
        payloads = cursor.fetchall()
        cursor.execute("SELECT * FROM captured_passwords")
        passwords = cursor.fetchall()
        conn.close()
        
        data = {
            "export_date": str(datetime.now()),
            "user": self.current_user['username'],
            "payloads": payloads,
            "captured_passwords": passwords
        }
        
        filename = f"export_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
        with open(filename, 'w') as f:
            json.dump(data, f, default=str, indent=2)
            
        print(f"{Colors.GREEN}[+] Exported to {filename}{Colors.RESET}")
        input(f"{Colors.DIM}Press Enter...{Colors.RESET}")
        
    def change_password(self):
        """Change user password"""
        print(f"\n{Colors.CYAN}[*] Change Password{Colors.RESET}\n")
        
        current = getpass.getpass(f"{Colors.WHITE}Current Password: {Colors.RESET}")
        new = getpass.getpass(f"{Colors.WHITE}New Password: {Colors.RESET}")
        confirm = getpass.getpass(f"{Colors.WHITE}Confirm: {Colors.RESET}")
        
        if new != confirm:
            print(f"{Colors.RED}[-] Passwords don't match{Colors.RESET}")
            input(f"{Colors.DIM}Press Enter...{Colors.RESET}")
            return
            
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute("SELECT salt FROM users WHERE username = ?", (self.current_user['username'],))
        result = cursor.fetchone()
        
        if result:
            salt = result[0]
            current_hash = hashlib.pbkdf2_hmac('sha256', current.encode(), salt.encode(), 100000).hex()
            cursor.execute("SELECT id FROM users WHERE username = ? AND password_hash = ?", 
                          (self.current_user['username'], current_hash))
            if cursor.fetchone():
                new_hash = hashlib.pbkdf2_hmac('sha256', new.encode(), salt.encode(), 100000).hex()
                cursor.execute("UPDATE users SET password_hash = ? WHERE username = ?", 
                              (new_hash, self.current_user['username']))
                conn.commit()
                print(f"{Colors.GREEN}[+] Password changed!{Colors.RESET}")
            else:
                print(f"{Colors.RED}[-] Current password incorrect{Colors.RESET}")
        conn.close()
        input(f"{Colors.DIM}Press Enter...{Colors.RESET}")
        
    def run(self):
        """Main loop"""
        if not self.login():
            print(f"{Colors.RED}[-] Too many failed attempts{Colors.RESET}")
            sys.exit(1)
            
        while True:
            self.clear_screen()
            self.print_menu()
            
            choice = input(f"{Colors.GREEN}choice>{Colors.RESET} ").strip()
            
            if choice == "0":
                print(f"{Colors.GREEN}[+] Goodbye!{Colors.RESET}")
                break
            elif choice == "1":
                self.save_payload()
            elif choice == "2":
                self.view_payloads()
            elif choice == "3":
                self.view_payload()
            elif choice == "4":
                self.delete_payload()
            elif choice == "5":
                self.save_password()
            elif choice == "6":
                self.view_passwords()
            elif choice == "7":
                self.search()
            elif choice == "8":
                self.export()
            elif choice == "9":
                self.change_password()
            else:
                print(f"{Colors.RED}[-] Invalid choice{Colors.RESET}")
                time.sleep(1)

if __name__ == "__main__":
    db = PayloadDatabase()
    db.run()
